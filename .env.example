# ThreatVision Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Anthropic API Key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# PostgreSQL
POSTGRES_USER=threatvision
POSTGRES_PASSWORD=threatvision
POSTGRES_DB=threatvision
POSTGRES_URL=postgresql+asyncpg://threatvision:threatvision@localhost:5432/threatvision
POSTGRES_URL_SYNC=postgresql://threatvision:threatvision@localhost:5432/threatvision

# Redis
REDIS_URL=redis://localhost:6379/0

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Auth
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
